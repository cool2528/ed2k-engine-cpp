{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "generator": "Visual Studio 17 2022",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build/default",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "default-release",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build/default-release"
    },
    {
      "name": "linux-release",
      "inherits": "linux",
      "binaryDir": "${sourceDir}/build/linux-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default", "configuration": "Debug" },
    { "name": "linux", "configurePreset": "linux" },
    { "name": "default-release", "configurePreset": "default-release", "configuration": "Release" },
    { "name": "linux-release", "configurePreset": "linux-release" }
  ],
  "testPresets": [
    { "name": "default", "configurePreset": "default", "configuration": "Debug",
      "output": { "outputOnFailure": true } },
    { "name": "linux", "configurePreset": "linux",
      "output": { "outputOnFailure": true } },
    { "name": "default-release", "configurePreset": "default-release", "configuration": "Release",
      "output": { "outputOnFailure": true } },
    { "name": "linux-release", "configurePreset": "linux-release",
      "output": { "outputOnFailure": true } }
  ]
}
