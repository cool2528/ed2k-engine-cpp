#pragma once
#include <string_view>

#define ED2K_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define ED2K_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define ED2K_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define ED2K_VERSION_STRING "@PROJECT_VERSION@"

#define ED2K_VERSION_AT_LEAST(major, minor, patch) \
  ((ED2K_VERSION_MAJOR > (major)) || \
   (ED2K_VERSION_MAJOR == (major) && ED2K_VERSION_MINOR > (minor)) || \
   (ED2K_VERSION_MAJOR == (major) && ED2K_VERSION_MINOR == (minor) && ED2K_VERSION_PATCH >= (patch)))

namespace ed2k {

inline constexpr int version_major = ED2K_VERSION_MAJOR;
inline constexpr int version_minor = ED2K_VERSION_MINOR;
inline constexpr int version_patch = ED2K_VERSION_PATCH;

std::string_view version() noexcept;

}
